{% set video_attributes = video_attributes|default(create_attribute()) %}

{# Compute attribute values #}
{% set video_autoplay = autoplay ?: false %}
{% set video_muted = muted ?: false %}
{% set video_loop = loop ?: false %}
{% set video_aria_label = caption ?: false %}
{% set video_poster = poster.src ?: false %}
{% set is_autoplay = autoplay ? 'yes' : 'no' %}

{% set attrs = {
  'autoplay': autoplay,
  'muted': muted,
  'loop': loop,
  'aria-label': caption,
  'poster': poster.src,
} %}

{% for key, value in attrs %}
	{% do video_attributes.setAttribute(key, value) %}
{% endfor %}

<figure {{ attributes }}>
  <video
    {{ video_attributes
      .setAttribute('autoplay', video_autoplay)
      .setAttribute('muted', video_muted)
      .setAttribute('loop', video_loop)
      .setAttribute('aria-label', video_aria_label)
      .setAttribute('poster', video_poster)
    }}
    src="{{ media.src }}"
  >
    Your browser does not support the video tag.
  </video>
  {% if controls %}
    <tac-controls>
      <button
        aria-label="{{ autoplay ? 'Pause video' : 'Play video' }}"
        class="text-white cursor-pointer"
      >
        <span class="video-icon-play{{ autoplay ? ' hidden' : '' }}">
          {% include "tac:icon" with {
            icon: "play-circle",
          } only %}
        </span>
        <span class="video-icon-pause{{ autoplay ? '' : ' hidden' }}">
          {% include "tac:icon" with {
            icon: "pause-circle",
          } only %}
        </span>
      </button>
    </tac-controls>
  {% endif %}
</figure>
