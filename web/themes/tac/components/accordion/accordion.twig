{% set attrs = {
  'open': variant|default,
  'name': 'accordion-panel'|clean_unique_id,
} %}

{% for key, value in attrs %}
	{% do attributes.setAttribute(key, value) %}
{% endfor %}

{% set attributes = attributes.setAttribute('open', open_by_default) %}

<details {{ attributes }}>
  <!-- sparkles icon -->
  <summary>
    {% include "tac:icon" ignore missing with {
      icon,
      icon_size: 'small',
    } %}         
    <span>{{ title }}</span>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
      <path fill-rule="evenodd" d="M12 3.75a.75.75 0 0 1 .75.75v6.75h6.75a.75.75 0 0 1 0 1.5h-6.75v6.75a.75.75 0 0 1-1.5 0v-6.75H4.5a.75.75 0 0 1 0-1.5h6.75V4.5a.75.75 0 0 1 .75-.75Z" clip-rule="evenodd" />
    </svg>          
  </summary>
  <tac-accordion-content>
    {% block accordion_content %}

    {% endblock %}
  </tac-accordion-content>
</details>